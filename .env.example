# Copy to .env and fill in. Loaded by your shell / docker; never commit the real .env.
# In App Platform these are set as SECRET env vars (see .do/app.yaml).

# --- Database ---
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=media;Username=media;Password=media

# --- Sessions ---
# Nothing to set: sessions are random per-login tokens stored (hashed) in the database, so there
# is no signing secret to leak or rotate. Defaults live in appsettings.json; override
# Session__LifetimeDays to change how long an idle session survives.

# --- Registration gate ---
# Shared invite code required to create an account. Empty (the default here, matching
# appsettings.json) refuses all signups — fail-closed. Set a long random string to open
# registration; rotate by changing it and restarting. See docs/registration-gate-design.md.
Registration__InviteCode=

# --- Cloudflare R2 ---
Storage__AccountId=your-r2-account-id
Storage__AccessKey=your-r2-access-key
Storage__SecretKey=your-r2-secret-key
Storage__Bucket=media
# Leave ServiceUrl empty for R2 (derived from AccountId). Dev uses MinIO via appsettings.Development.json.
Storage__ServiceUrl=
# Host baked into presigned URLs, i.e. the one the BROWSER must reach. Leave empty unless the API
# reaches storage by a name the browser can't resolve (e.g. the API in Docker using "minio:9000"
# while the browser needs "localhost:9000"). Empty = same as ServiceUrl, which is right for R2.
Storage__PublicUrl=
