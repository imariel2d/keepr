{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=media;Username=media;Password=media"
  },
  "Jwt": {
    "Issuer": "media-api",
    "Audience": "media-app",
    "SigningKey": "CHANGE_ME_use_env_var_in_production_min_32_chars",
    "AccessTokenMinutes": 60
  },
  "Storage": {
    "AccountId": "",
    "AccessKey": "",
    "SecretKey": "",
    "Bucket": "media",
    "ServiceUrl": "",
    "PresignExpiryMinutes": 15
  },
  "Quota": {
    "DefaultBytes": 5368709120
  },
  "Cleanup": {
    "IntervalMinutes": 30,
    "PendingMaxAgeHours": 24
  }
}
